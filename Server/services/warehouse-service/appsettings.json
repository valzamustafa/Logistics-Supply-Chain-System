{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "WarehouseDB": "Server=(localdb)\\mssqllocaldb;Database=WarehouseServiceDB_v2;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Services": {
    "ProductService": "http://localhost:5001"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForAuthService123!",
    "Issuer": "Logjistika",
    "Audience": "LogjistikaClients"
  },
  "StockSettings": {
    "DefaultMinimumStockLevel": 5,
    "DefaultMaximumStockLevel": 1000,
    "LowStockAlertThreshold": 10,
    "EnableAutoRestock": false
  },
  "AllowedHosts": "*"
}
