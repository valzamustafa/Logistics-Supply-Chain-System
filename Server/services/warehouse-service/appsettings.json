{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "WarehouseService.Business.WarehouseService": "Debug"
    }
  },
  "ConnectionStrings": {
    "WarehouseDB": "Server=(localdb)\\mssqllocaldb;Database=WarehouseServiceDB_v3;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Services": {
    "ProductService": "http://localhost:5000"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForAuthService123!",
    "Issuer": "AuthService",
    "Audience": "LogisticsSystem"
  },
  "StockSettings": {
    "DefaultMinimumStockLevel": 5,
    "DefaultMaximumStockLevel": 1000,
    "LowStockAlertThreshold": 10,
    "EnableAutoRestock": false
  },
  "AllowedHosts": "*"
}